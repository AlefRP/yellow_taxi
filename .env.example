# Copie para .env e preencha. NÃO comite o .env real.
# Em produção, prefira Airflow Variables / Secret Manager — o código lê na
# ordem: Airflow Variable → variável de ambiente → default.

# =============================================================================
# GCP — projeto, região, BigQuery
# =============================================================================
GCP_PROJECT_ID=dbtbigq-450122
GCP_REGION=us-central1
BQ_DATASET=taxis_ny
BQ_RAW_TABLE=yellow_taxi
BQ_LOCATION=US

# =============================================================================
# GCS — camadas raw (parquet) e bronze (Iceberg)
# =============================================================================
GCS_BUCKET=dbt_teste
GCS_RAW_PREFIX=raw/yellow_tripdata
GCS_BRONZE_PREFIX=bronze/yellow_taxi

# =============================================================================
# BigLake — connection usada pela tabela externa Iceberg
# Formato: <project>.<region>.<connection_id>
# Crie com: bq mk --connection --location=US --project_id=<proj> \
#                 --connection_type=CLOUD_RESOURCE biglake_conn
# =============================================================================
BIGLAKE_CONNECTION=dbtbigq-450122.us.biglake_conn

# =============================================================================
# Cloud Run Job — ingestão Kaggle → GCS
# =============================================================================
CLOUD_RUN_REGION=us-central1
CLOUD_RUN_JOB_NAME=yellow-taxi-ingest

# =============================================================================
# Kaggle — credenciais do dataset
# Setadas no Cloud Run Job via Secret Manager (não no Airflow)
# =============================================================================
KAGGLE_DATASET=elemento/nyc-yellow-taxi-trip-data
KAGGLE_USERNAME=
KAGGLE_KEY=

# =============================================================================
# Airflow — connections referenciadas pelos DAGs
# - my_bigquery_connection (Google Cloud, com a service account JSON)
# Configure via airflow_settings.yaml ou na UI.
# =============================================================================

# =============================================================================
# Alertas (opcional) — emails separados por vírgula
# =============================================================================
ALERT_EMAILS=alefrodrigopereira@yahoo.com.br
